generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TripStatus {
  draft
  active
  sold_out
  finished
  inactive
  canceled
}

enum TripExperienceType {
  trail
  tour
  camping
  expedition
}

enum TripAttractionType {
  mountain
  trail
  viewpoint
  waterfall
  canyon
  river_aquatrekking
  beach
  rappel
  bungee_jump
  cave
  sunrise
  sunset
}

enum TripDifficulty {
  easy
  moderate
  hard
  very_hard
}

enum ReservationStatus {
  pending
  payment_pending
  confirmed
  canceled
}

enum UserRole {
  super_admin
  admin_operacao
  partner
  guia
  atendimento
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum TrilheiroStatus {
  INCOMPLETE
  ACTIVE
  BLOCKED
  ARCHIVED
}

enum TrilheiroRegistrationStep {
  minimal
  contact
  identity
  complete
}

model Trip {
  id             String             @id @default(cuid())
  slug           String             @unique
  title          String
  destination    String
  dateLabel      String
  eventDate      DateTime?
  departureTime  String?
  experienceType TripExperienceType @default(trail)
  type           String?
  difficulty     TripDifficulty     @default(moderate)
  duration       String?
  price          Decimal?           @db.Decimal(10, 2)
  capacity       Int?
  summary        String?
  description    String?
  itinerary      Json?
  includedItems  Json?
  mainImageUrl   String?
  paymentLink    String?
  whatsappLink   String?
  status         TripStatus         @default(draft)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  reservations   Reservation[]
  boardingPoints TripBoardingPoint[]
  interests      TripInterest[]
  mediaAssets    MediaAsset[]
}

model Reservation {
  id              String             @id @default(cuid())
  trilheiroId     String?
  tripId          String
  fullName        String
  email           String
  whatsapp        String
  cpf             String?
  birthDate       DateTime?
  boardingPointId String?
  notes           String?
  status          ReservationStatus  @default(pending)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  trilheiro       Trilheiro?         @relation(fields: [trilheiroId], references: [id], onDelete: SetNull)
  trip            Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  boardingPoint   TripBoardingPoint? @relation(fields: [boardingPointId], references: [id], onDelete: SetNull)

  @@index([trilheiroId])
  @@index([tripId])
  @@index([status])
}

model TripBoardingPoint {
  id           String        @id @default(cuid())
  tripId       String
  label        String
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  trip         Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([tripId])
}

model TripInterest {
  id           String             @id @default(cuid())
  tripId       String
  type         TripAttractionType
  order        Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  trip         Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, type])
  @@index([tripId])
}

model User {
  id              String       @id @default(cuid())
  name            String
  email           String       @unique
  passwordHash    String
  role            UserRole     @default(admin_operacao)
  status          UserStatus   @default(ACTIVE)
  avatarUrl       String?
  phone           String?
  preferences     Json?
  lastLoginAt     DateTime?
  refreshTokenHash String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  mediaAssets     MediaAsset[]
}

model Trilheiro {
  id                String                     @id @default(cuid())
  fullName          String
  email             String                     @unique
  phone             String?
  documentNumber    String?
  birthDate         DateTime?
  avatarUrl         String?
  status            TrilheiroStatus            @default(INCOMPLETE)
  registrationStep  TrilheiroRegistrationStep  @default(minimal)
  preferences       Json?
  lastAccessAt      DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  reservations      Reservation[]
}

model MediaAsset {
  id          String   @id @default(cuid())
  key         String   @unique
  url         String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  alt         String?
  tripId      String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trip        Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  user        User?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([uploadedBy])
}
